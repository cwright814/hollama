# .aiexclude
# Google Antigravity & AI Coding Assistant Exclusions
#
# This file lists patterns of files and folders that should not be read or indexed.
# Excluding large, binary, auto-generated, or frequently modified files is critical to:
#  1. Preserve prompt cache hit rates (dynamic or very large contexts invalidate cache).
#  2. Reduce token costs and avoid hitting context window limits.
#  3. Keep the AI assistant focused strictly on relevant codebase logic.

# --- Version Control & Local CLI Caches ---
.git/
.gitignore
.gitattributes
.github/
.antigravitycli/
.cursor/
.vscode/
.idea/

# --- Dependencies & Package Lockfiles ---
# Lockfiles are huge, machine-generated, and change frequently, which invalidates prompt cache.
package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lockb
node_modules/

# --- Build and Development Artifacts ---
# Auto-generated files that change on every build/run.
build/
dist/
.svelte-kit/
.wrangler/
out/
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# --- Environment & Sensitive Variables ---
.env
.env.*
!.env.example

# --- Logs & Temp Files ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.eslintcache

# --- Test Outputs & Coverage Reports ---
test-results/
coverage/
.nyc_output/
tests/docs.test.ts-snapshots/
**/*.test.ts.snap
**/*.test.js.snap

# --- Media, Fonts, & Binaries ---
# Static assets and binary files that the AI cannot process and only clutter the index.
static/fonts/
**/*.png
**/*.jpg
**/*.jpeg
**/*.gif
**/*.svg
**/*.ico
**/*.webp
**/*.pdf
**/*.zip
**/*.tar.gz
**/*.mp4
**/*.mp3
**/*.wav
**/*.woff
**/*.woff2
**/*.eot
**/*.ttf
